{
  "name": "@angora/api",
  "version": "1.0.0",
  "description": "Angora API — Express + BullMQ + Prisma trading engine",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@google/generative-ai": "latest",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "latest",
    "@supabase/supabase-js": "latest",
    "@types/pg": "^8.20.0",
    "bullmq": "latest",
    "cors": "latest",
    "ethers": "^6.14.0",
    "express": "latest",
    "ioredis": "latest",
    "pg": "^8.20.0",
    "prisma": "latest",
    "uuid": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/node": "latest",
    "@vitest/coverage-v8": "latest",
    "nodemon": "latest",
    "supertest": "latest",
    "ts-node": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
